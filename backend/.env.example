# ===========================================================
# CONFIGURACION DE PRODUCCION - backend
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas .env a git -- ya esta en .gitignore
# ===========================================================

# Puerto del servidor
PORT=4201

# Cadena de conexion MongoDB
# Local:   mongodb://127.0.0.1:27017/tienda
# Atlas:   mongodb+srv://USUARIO:PASSWORD@cluster0.xxxxx.mongodb.net/tienda
MONGODB_URI=mongodb://127.0.0.1:27017/tienda

# Secreto para firmar tokens JWT de administradores/colaboradores
# GENERA UNO SEGURO CON: node -e "const c=require('crypto');c.randomBytes(64,(e,b)=>console.log(b.toString('hex')))"
JWT_SECRET=REEMPLAZA_CON_64_BYTES_HEX_ALEATORIO

# Secreto para firmar tokens JWT de clientes de la tienda
# Usa un valor DIFERENTE al JWT_SECRET
JWT_SECRET_CLIENTE=REEMPLAZA_CON_OTRO_64_BYTES_HEX_ALEATORIO

# Origenes permitidos en CORS (separados por coma, sin espacios)
# Produccion: https://tu-tienda.com,https://tu-panel.com
CORS_ORIGINS=http://localhost:8080,http://localhost:8081

# ===========================================================
# DATOS INICIALES DEL ADMINISTRADOR
# Solo se usan al ejecutar: node scripts/crear_admin.js
# Una vez creado el admin, estas variables ya no son necesarias
# ===========================================================
ADMIN_NOMBRE=Admin
ADMIN_APELLIDO=Principal
ADMIN_EMAIL=tu_email@ejemplo.com
ADMIN_PASSWORD=REEMPLAZA_CON_CONTRASENA_SEGURA_MIN_8_CHARS
