# ===========================================================
# CONFIGURACIÓN DE PRODUCCIÓN — panel admin
# Copia este archivo como .env y rellena los valores reales
# ===========================================================

# URL base del backend (sin /api al final)
# Local:       http://localhost:4201
# Producción:  https://tu-backend.onrender.com
VUE_APP_API_URL=http://localhost:4201

# Margen de ganancia (%) — se usa en cálculos de precio del panel
# Si no se define, el valor por defecto es 30
VUE_APP_GANANCIA=30
